# ─── Binance API Keys ───────────────────────────────────────
# Testnet (gefahrlos testen): https://testnet.binance.vision/
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ─── Modus ──────────────────────────────────────────────────
# "testnet" = Binance Testnet (kein echtes Geld)
# "live"    = Echter Handel (VORSICHT!)
TRADING_MODE=testnet

# ─── Symbol & Timeframe ─────────────────────────────────────
SYMBOL=BTCUSDT
INTERVAL=15m

# ─── Risiko ─────────────────────────────────────────────────
# Wieviel % des Kontos pro Trade riskieren (z.B. 1.0 = 1%)
ACCOUNT_RISK_PERCENT=1.0

# Maximales Kapital pro Trade in USDT (Sicherheits-Limit)
MAX_TRADE_USDT=100.0
